  background-color: #faf7f2;
	border-radius: 20px
}

/* Anfrage-Button */
#menu-item-1996 .avia-menu-text {
  border-radius: 120px !important;
  padding: 10px 30px !important;
}

#top #wrap_all .header_color .av-menu-button-colored > a .avia-menu-text {
  border-radius: 120px;
  padding: 15px 40px;
}

