<style id="wp-custom-css">

/* Logo-Styles */
.logo.avia-svg-logo {
  display: block;
  max-width: 450px;
  width: 450px;
  height: auto;
  margin-top: 15px;
}

.my-svg-logo img {
  width: 300px;
  height: auto;
  max-width: 400px;
}

@media only screen and (max-width: 1140px) {
  .logo.avia-svg-logo {
  max-width: 300px;
  width: 300px;
  margin-top: 25px;
  }
}

