.my-fixed-size {
  height: 125px !important;
  overflow: hidden;
}

/* Absatz in aprokt */
.aprokt p {
  margin: 0;
}

.avia-button.avia-size-large {
  min-width: 250px;
  display: inline-block;
  font-size: 16px;
  border: 2px solid #ff6600; /* Rahmen */
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-sizing: border-box; /* Stellt sicher, dass die Skalierung sich auf den gesamten Button bezieht */
}

.avia-button.avia-size-large:hover {
  transform: scale(1.05); /* Zoom-Effekt */
  box-shadow: 0px 0 15px rgba(0, 0, 0, 0.3); /* Weicher Schatten */
}

.avia-button.avia-size-large:active {
  transform: scale(1); /* Verkleinern beim Klicken */
