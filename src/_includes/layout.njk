.test .my-flex-column {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-bottom: 130px !important;
}

.test .my-flex-column .my-bottom-button {
  margin-top: auto;
}

.test .my-bottom-button {
  position: absolute;
  transform: translate(-50%, -50%);
  bottom: 30px !important;
  left: 50% !important;
}

/* Equal Height Section */
.equal-height-section {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
}

.equal-height-section > * {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Tour */
.tour {
  position: relative;
  transform: translate(-50%, -50%);
  margin-top: 110px !important;
  left: 50% !important;
  width: 50%;
}

/* Virtuelle Tour auf kleinen Bildschirmen */
@media only screen and (max-width: 768px) {
  .virtuelletour .iconbox_top .iconbox_content {
    padding-left: 0;
    padding-right: 0;
    padding-bottom: 0;
    background: #ffffff;
    box-shadow: none !important;
  }
}

/* Responsive Einstellungen für Animated Number und Facts */
