		padding-top: 10px
  }
  .responsive #top #wrap_all .my-masonry-col .flex_cell {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }
}

.catererreiter .avia-icon-list-container {
  margin: 0 !important;
}

@media only screen and (min-width: 767px) and (max-width: 1340px) {
