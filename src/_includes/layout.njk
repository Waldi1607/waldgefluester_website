@media only screen and (min-width: 1401px) {
  .avia-animated-number.factnumber .avia-animated-number-circle {
    width: 50% !important;
  }
}

/* Custom Form Button */
#top .av-custom-form-color .button {
  border: 0;
  border-radius: 30px;
  background-color: var(--enfold-alternate-color-primary);
  color: white;
}

.iconbox_top .iconbox_content {
  transition: transform 0.3s ease, box-shadow 0.3s ease;
	box-shadow: 0 0 10px 0 #d6d6d6;
  border-radius: 20px

}

.iconbox_top .iconbox_content:hover{
  transform: scale(1.02); /* 10% Vergrößerung */
  box-shadow: 0px 0 15px rgba(0, 0, 0, 0.3); /* Weicher Schatten */
}

.iconbox_top .iconbox_content:active {
  transform: scale(1); /* Verkleinern beim Klicken */
  box-shadow: 0px 0px 0px rgba(0, 0, 0, 0.2); /* Schatten reduzieren */
}

.avia-slideshow-carousel ul {
    padding: 15px;
}

.termine-container {
    display: flex;
    flex-wrap: wrap;  /* Falls zu viele Termine vorhanden sind, werden sie umgebrochen */
    gap: 40px; /* Abstand zwischen den Terminen */
    justify-content: center; /* Zentriert die Termine */
		padding: 50px
}

.termin-box {
    background-color: var(--enfold-alternate-color-primary);
    color: #ffffff !important; /* Setzt die Schriftfarbe auf Weiß */
    padding: 8px 25px;
		min-width: 300px;
    border-radius: 130px;
    font-size: 1rem;
    white-space: nowrap; /* Verhindert Zeilenumbrüche */
    text-align: center;
    text-decoration: none; /* Entfernt Unterstreichung */
    transition: background-color 0.3s ease-in-out, transform 0.2s;

    /* Macht die Boxen klickbar */
    display: inline-block;
}

.termin-box:hover {
    transform: scale(1.02); /* Leichtes Vergrößern */
    transition: background-color 0.3s ease-in-out, transform 0.2s;
  box-shadow: 0px 0 15px rgba(0, 0, 0, 0.1); /* Weicher Schatten */
}

.avia-no-number {
    opacity: .5;
    font-size: .6em;
