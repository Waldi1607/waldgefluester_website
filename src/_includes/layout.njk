.my-masonry-col .flex_cell {
  padding-left: 0 !important;
  padding-right: 0 !important;
  padding-top: 0 !important;
}

@media only screen and (max-width: 1051px) {
  .responsive #top #wrap_all .av-flex-cells .no_margin {
    padding-left: 4%;
    padding-right: 4%;
